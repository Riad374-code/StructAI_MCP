{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Riad374-code/StructAI/main/internal/spec/spec.schema.json",
  "title": "ArchitectMCP Architecture Spec",
  "description": "Machine-checkable architecture contract produced by architect_plan and enforced deterministically by architect_check. Shape-level rules live here; cross-field rules (reference resolution, uniqueness, contradictions) live in the Go semantic validator.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "spec_version", "spec_id", "project", "workspaces"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "spec_version": { "type": "integer", "minimum": 1 },
    "spec_id": { "$ref": "#/$defs/id" },
    "migration": { "$ref": "#/$defs/migration" },
    "project": { "$ref": "#/$defs/project" },
    "workspaces": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/workspace" }
    },
    "tech_stack": { "$ref": "#/$defs/techStack" },
    "ignore": { "$ref": "#/$defs/ignore" },
    "layers": { "type": "array", "items": { "$ref": "#/$defs/layer" } },
    "layer_rules": { "type": "array", "items": { "$ref": "#/$defs/layerRule" } },
    "layer_default": { "$ref": "#/$defs/layerDefaultRule" },
    "modules": { "type": "array", "items": { "$ref": "#/$defs/module" } },
    "phases": { "type": "array", "items": { "$ref": "#/$defs/phase" } },
    "constraints": { "type": "array", "items": { "$ref": "#/$defs/constraint" } }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$",
      "maxLength": 64
    },
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "glob": { "type": "string", "minLength": 1 },
    "severity": { "enum": ["critical", "high", "medium", "low"] },
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from_schema_version"],
      "properties": {
        "from_schema_version": { "$ref": "#/$defs/nonEmptyString" },
        "note": { "type": "string" }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "$ref": "#/$defs/nonEmptyString" },
        "description": { "type": "string" },
        "assumptions": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        }
      }
    },
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "root"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "root": { "$ref": "#/$defs/nonEmptyString" },
        "language": { "type": "string" },
        "package_manager": { "type": "string" }
      }
    },
    "techStack": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required": {
          "type": "array",
          "items": { "$ref": "#/$defs/techRequirement" }
        },
        "forbidden": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "rationales": {
          "type": "array",
          "items": { "$ref": "#/$defs/rationale" }
        }
      }
    },
    "techRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "choice"],
      "properties": {
        "category": { "$ref": "#/$defs/nonEmptyString" },
        "choice": { "$ref": "#/$defs/nonEmptyString" },
        "packages": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/nonEmptyString" }
        }
      }
    },
    "rationale": {
      "type": "object",
      "additionalProperties": false,
      "required": ["choice", "reason"],
      "properties": {
        "choice": { "$ref": "#/$defs/nonEmptyString" },
        "reason": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "ignore": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "paths": {
          "type": "array",
          "items": { "$ref": "#/$defs/ignoreEntry" }
        },
        "reason_required": { "type": "boolean" }
      }
    },
    "ignoreEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pattern"],
      "properties": {
        "pattern": { "$ref": "#/$defs/glob" },
        "reason": { "type": "string" }
      }
    },
    "layer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "paths", "order"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "paths": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/glob" }
        },
        "order": { "type": "integer" }
      }
    },
    "layerRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "from", "to", "allow", "severity"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "from": { "$ref": "#/$defs/id" },
        "to": { "$ref": "#/$defs/id" },
        "allow": { "type": "boolean" },
        "severity": { "$ref": "#/$defs/severity" },
        "message": { "type": "string" }
      }
    },
    "layerDefaultRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "allow", "severity"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "allow": { "type": "boolean" },
        "severity": { "$ref": "#/$defs/severity" },
        "message": { "type": "string" }
      }
    },
    "module": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "phase", "paths"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "package": { "$ref": "#/$defs/id" },
        "phase": { "type": "integer", "minimum": 1 },
        "paths": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/glob" }
        },
        "responsibility": { "type": "string" },
        "allow_empty": { "type": "boolean" },
        "allowed_deps": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" }
        },
        "required_exports": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "coupling_threshold": { "type": "integer", "minimum": 1 }
      }
    },
    "phase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "integer", "minimum": 1 },
        "name": { "$ref": "#/$defs/nonEmptyString" },
        "required_modules": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" }
        }
      }
    },
    "constraint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "severity"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "kind": {
          "enum": [
            "forbidden_dependency",
            "allowed_dependency",
            "layer_violation",
            "must_call",
            "required_export",
            "required_module",
            "coupling_threshold"
          ]
        },
        "from_module": { "$ref": "#/$defs/id" },
        "to_module": { "$ref": "#/$defs/id" },
        "from_layer": { "$ref": "#/$defs/id" },
        "to_layer": { "$ref": "#/$defs/id" },
        "module": { "$ref": "#/$defs/id" },
        "export": { "$ref": "#/$defs/nonEmptyString" },
        "dependency": { "$ref": "#/$defs/nonEmptyString" },
        "threshold": { "type": "integer", "minimum": 1 },
        "severity": { "$ref": "#/$defs/severity" },
        "message": { "type": "string" }
      }
    }
  }
}
